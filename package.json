{
  "name": "yuzz-cli",
  "version": "1.2.1",
  "description": "🤖 Yuzz — AI-powered terminal chat CLI using free AI models",
  "main": "src/index.js",
  "bin": {
    "yuzz": "./src/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start":      "node src/index.js",
    "dev":        "node src/index.js",
    "update":     "node src/index.js update",
    "repair":     "node src/index.js repair",
    "resetlimit": "node src/index.js resetlimit"
  },
  "keywords": ["ai", "cli", "terminal", "chatbot", "gemini", "openrouter", "open-source"],
  "author": "Yuzz Contributors",
  "license": "MIT",
  "dependencies": {
    "boxen":          "^7.1.1",
    "chalk":          "^5.3.0",
    "conf":           "^12.0.0",
    "gradient-string":"^2.0.2",
    "marked":         "^12.0.0",
    "marked-terminal":"^7.1.0",
    "node-fetch":     "^3.3.2",
    "ora":            "^8.0.1"
  }
}
